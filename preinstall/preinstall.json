{
    "dockerfile": [],
    "environment": [
        {
            "name": "golang",
            "version": "1.26.1",
            "url": "https://mirrors.aliyun.com/golang/go1.26.1.linux-amd64.tar.gz",
            "install": "mkdir -p /opt/tools/bin /opt/tools/go && wget -q $URL -O /tmp/go.tar.gz && tar -C /opt/tools -xzf /tmp/go.tar.gz && rm /tmp/go.tar.gz"
        },
        {
            "name": "node",
            "version": "20.18.0",
            "url": "https://registry.npmmirror.com/-/binary/node/v20.18.0/node-v20.18.0-linux-x64.tar.xz",
            "install": "mkdir -p /opt/tools/bin && wget -q $URL -O /tmp/node.tar.xz && tar -C /opt/tools -xJf /tmp/node.tar.xz --strip-components=1 && rm /tmp/node.tar.xz && npm config set registry https://registry.npmmirror.com"
        },
        {
            "name": "kubectl",
            "version": "1.31.0",
            "url": "https://dl.k8s.io/release/v1.31.0/bin/linux/amd64/kubectl",
            "install": "wget -q $URL -O /opt/tools/bin/kubectl && chmod +x /opt/tools/bin/kubectl"
        },
        {
            "name": "helm",
            "version": "3.17.2",
            "url": "https://mirrors.huaweicloud.com/helm/v3.17.2/helm-v3.17.2-linux-amd64.tar.gz",
            "install": "wget -q $URL -O /tmp/helm.tar.gz && tar -C /tmp -xzf /tmp/helm.tar.gz linux-amd64/helm && mv /tmp/linux-amd64/helm /opt/tools/bin/helm && rm -rf /tmp/helm.tar.gz /tmp/linux-amd64"
        },
        {
            "name": "opencode-ai",
            "version": "latest",
            "url": "https://www.npmjs.com/package/opencode-ai",
            "install": "npm install --production -g opencode-ai@latest"
        },
        {
            "name": "agent-browser",
            "version": "latest",
            "url": "https://www.npmjs.com/package/agent-browser",
            "install": "npm install --production -g agent-browser"
        },
        {
            "name": "buildah",
            "version": "1.37.3",
            "url": "https://packages.debian.org/bookworm/buildah",
            "install": "apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y -o Dpkg::Options::='--force-confdef' -o Dpkg::Options::='--force-confold' buildah || dpkg --configure -a"
        }
    ],
    "opencode": [
        {
            "name": "oh-my-opencode",
            "url": "https://gh-proxy.com/https://github.com/code-yeongyu/oh-my-opencode",
            "install_doc": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/refs/heads/master/docs/guide/installation.md",
            "install": "npm install --production -g oh-my-opencode && oh-my-opencode install --no-tui --claude=no --openai=no --gemini=no --copilot=no || true"
        },
        {
            "name": "superpowers",
            "url": "https://gh-proxy.com/https://github.com/obra/superpowers",
            "install_doc": "先把git代码下载到/opt/preinstall/.config/opencode下，然后把superpowers/.opencode/plugins/superpowers.js复制到/opt/preinstall/.config/opencode/plugins/下，把superpowers/skills/*复制到/opt/preinstall/.config/opencode/skills/superpowers下",
            "install": "git clone --depth 1 $URL /opt/preinstall/.config/opencode/superpowers && mkdir -p /opt/preinstall/.config/opencode/plugins /opt/preinstall/.config/opencode/skills/superpowers && cp /opt/preinstall/.config/opencode/superpowers/.opencode/plugins/superpowers.js /opt/preinstall/.config/opencode/plugins/ && cp -r /opt/preinstall/.config/opencode/superpowers/skills/* /opt/preinstall/.config/opencode/skills/superpowers/"
        },
        {
            "name": "minimax-skills",
            "url": "https://gh-proxy.com/https://github.com/MiniMax-AI/skills.git",
            "install_doc": "git clone https://github.com/MiniMax-AI/skills.git 把skills/*复制到/opt/preinstall/.config/opencode/skills/下",
            "install": "git clone --depth 1 $URL /opt/preinstall/.config/opencode/minimax-skills && cp -r /opt/preinstall/.config/opencode/minimax-skills/skills/* /opt/preinstall/.config/opencode/skills/"
        }
    ]
}
